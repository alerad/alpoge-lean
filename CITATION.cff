cff-version: 1.2.0
message: "If you use this formalization, please cite it as below."
title: "Formal verification and structure theory of Alpöge's counterexample to the Jacobian Conjecture"
type: software
authors:
  - given-names: Alejandro
    family-names: Radisic
    orcid: "https://orcid.org/0009-0001-7612-1082"
repository-code: "https://github.com/alerad/alpoge-lean"
